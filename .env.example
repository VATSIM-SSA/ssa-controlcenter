# === Basics ===
APP_NAME="VATSSA Control Center"
APP_ENV=production
APP_URL="https://cc.vatssa.com"
APP_MODE=division
APP_OWNER_NAME="VATSSA"
APP_OWNER_NAME_SHORT="SSA"
APP_OWNER_CODE="SSA"
APP_KEY=  # <-- see bootstrap steps below

# === Database (DO Managed MySQL) ===
DB_CONNECTION=mysql
DB_HOST=<do-managed-mysql-host>
DB_PORT=25060
DB_DATABASE=cc_prod
DB_USERNAME=cc_app
DB_PASSWORD=<secret>    # store only on droplet

# === OAuth / Auth (VATSIM Connect or Handover) ===
OAUTH_URL="https://auth.vatsim.net"
OAUTH_ID=<your-client-id>
OAUTH_SECRET=<your-client-secret>

# === VATSIM integrations (optional but recommended) ===
VATSIM_CORE_API_TOKEN=<core-v2-token>
VATSIM_BOOKING_API_URL="https://atc-bookings.vatsim.net/api"
VATSIM_BOOKING_API_TOKEN=<booking-token>

# === Mail (SES API – SMTP ports are blocked on DigitalOcean) ===
MAIL_MAILER=ses
MAIL_FROM_NAME="VATSSA Control Center"
MAIL_FROM_ADDRESS="noreply@vatssa.com"

# === AWS (SES API credentials) ===
AWS_ACCESS_KEY_ID=<your-ses-key>
AWS_SECRET_ACCESS_KEY=<your-ses-secret>
AWS_DEFAULT_REGION=eu-central-1

# === Reverse proxy trust ===
TRUSTED_PROXIES=*
